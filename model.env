# =============================================================================
#  model.env - FONTE UNICA DE VERDADE para valores que precisam bater entre
#  TODOS os ambientes deste repo: container de conversao (scripts/,
#  calibration/), board_test/ (Python) e native_infer/ (C). Ver CLAUDE.md,
#  secao "Environments & shared data", para o mapa completo de quem le' o que.
#
#  Formato KEY=VALUE simples, SEM espacos ao redor do "=" - de proposito,
#  pra funcionar tanto com `source` (bash) quanto com `include` (Makefile)
#  quanto com um parser de 5 linhas em Python. Nao vire um .yaml/.json.
#
#  Se mudar de modelo/resolucao/placa, edite AQUI. Os scripts leem este
#  arquivo como default (se nao encontrarem o arquivo, caem pro valor
#  hardcoded no proprio CONFIG - mesmo comportamento de sempre, sem quebrar
#  o padrao "sem argparse, explicito" do projeto).
# =============================================================================

# Resolucao de entrada do modelo (lado do quadrado). Os 3 modelos atuais em
# input-models/ (nano/large/extra-large) foram treinados em 1280.
# Usado por: scripts/01_pt_to_onnx.py, scripts/02_onnx_to_dlc.py,
# calibration/gen_calibration.py, board_test/01_capture_frames.py.
IMGSZ=1280

# Nome do tensor de entrada do ONNX exportado (YOLOv8/11 = "images").
# Usado por: scripts/02_onnx_to_dlc.py.
INPUT_NAME=images

# Nome interno do grafo dentro do .dlc/.bin. NAO e' um nome livre: o
# qairt-converter usa o STEM do --output_path (DLC_OUT em
# scripts/02_onnx_to_dlc.py) como nome do grafo. Hoje DLC_OUT termina em
# "modelo_fp.dlc" -> o grafo se chama "modelo_fp". Se renomear DLC_OUT no
# passo 02, atualize aqui tambem (confirme com native_infer/qnn_infer, que
# lista os grafos do .bin se o nome nao bater).
# Usado por: scripts/04_dlc_to_context.py (vtcm config), native_infer/ (qual
# grafo recuperar via QnnGraph_retrieve).
GRAPH_NAME=modelo_fp

# SoC da placa (Radxa Dragon Q6A / QCS6490, HTP v68). So' muda se trocar de
# placa - nao mexa nisso por engano ao trocar de MODELO.
# Usado por: scripts/04_dlc_to_context.py.
DSP_ARCH=v68
SOC_ID=35
