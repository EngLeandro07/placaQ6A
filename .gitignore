#Agentes CoWork
CLAUDE.md
.claude

__pycache__/
*.pyc

# Modelos treinados (grandes, específicos de cada execução)
input-models/*.pt

# Dataset e artefatos de calibração (gerados/locais)
calibration/dataset/*
calibration/calib_raw/*
calibration/input_list.txt

# Saídas do pipeline (.onnx, .dlc, .bin, configs gerados)
workspace/*

# Teste de webcam na placa: capturas, saídas do qnn-net-run e o modelo
# copiado (scp) pra dentro de board_test/ pra rodar lá - tudo gerado/local.
board_test/captures/
board_test/outputs/
board_test/input_list.txt
board_test/*.dlc
board_test/*.bin
board_test/venv/

# Inferência nativa em C: binário compilado (na placa) e o .bin copiado pra lá
native_infer/qnn_infer
native_infer/*.bin
native_infer/*.dlc

# mantém as pastas no git mesmo com o conteúdo ignorado
!input-models/.gitkeep
!calibration/dataset/.gitkeep
!calibration/calib_raw/.gitkeep
!workspace/.gitkeep